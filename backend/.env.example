# Configurações do servidor KaryoScan
# Copie este arquivo para .env e edite os valores antes de rodar

# Porta do servidor HTTP
PORT=3000

# Segredo JWT — MUDE para uma string longa e aleatória antes de ir para produção!
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_ESTE_SEGREDO_POR_UM_VALOR_ALEATORIO_LONGO

# Credenciais do superadmin (criadas automaticamente na primeira execução)
ADMIN_EMAIL=admin@karyoscan.com.br
ADMIN_PASSWORD=KaryoScan@2026!

# Origens CORS permitidas (separadas por vírgula, sem espaços)
# Em produção, use o domínio real onde o frontend está hospedado
ALLOWED_ORIGINS=http://localhost:3000,https://karyoscan.seudominio.com.br
